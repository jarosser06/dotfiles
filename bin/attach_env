#!/bin/bash

# Script to attach to a running devcontainer
# Usage:
#   ./attach_env                  # Auto-detect from current directory
#   ./attach_env <project_name>   # Attach to specific project

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to get project name from current directory
get_project_from_pwd() {
    local current_dir=$(pwd)

    # Check if .devcontainer exists in current directory
    if [ ! -d ".devcontainer" ]; then
        echo -e "${RED}❌ No .devcontainer directory found in current directory${NC}" >&2
        echo -e "${YELLOW}💡 Make sure you're in the project root directory${NC}" >&2
        return 1
    fi

    # Try to extract project name from .devcontainer/devcontainer.json
    if [ -f ".devcontainer/devcontainer.json" ]; then
        local container_name=$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' .devcontainer/devcontainer.json | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
        if [ -n "$container_name" ]; then
            echo "$container_name"
            return 0
        fi
    fi

    # Try to extract from docker-compose.yml
    if [ -f ".devcontainer/docker-compose.yml" ]; then
        local compose_name=$(grep -o 'container_name:[[:space:]]*[^[:space:]]*' .devcontainer/docker-compose.yml | head -1 | awk '{print $2}')
        if [ -n "$compose_name" ]; then
            echo "$compose_name"
            return 0
        fi
    fi

    # Fallback to directory name
    basename "$current_dir"
}

# Function to normalize project name for container matching
# Extracts key identifier from full project name
normalize_project_name() {
    local project_name="$1"
    # Convert to lowercase and take first word as the key identifier
    echo "$project_name" | tr '[:upper:]' '[:lower:]' | awk '{print $1}'
}

# Determine project name
if [ -z "$1" ]; then
    echo -e "${BLUE}🔍 Auto-detecting project from current directory...${NC}"
    PROJECT_NAME=$(get_project_from_pwd)
    if [ $? -ne 0 ]; then
        exit 1
    fi
    echo -e "${GREEN}✓ Detected project: ${PROJECT_NAME}${NC}"
else
    PROJECT_NAME="$1"
    echo -e "${BLUE}🔍 Looking for project: ${PROJECT_NAME}${NC}"
fi

echo -e "${BLUE}🔍 Looking for ${PROJECT_NAME} devcontainer...${NC}"

# Normalize project name for flexible matching
NORMALIZED_NAME=$(normalize_project_name "$PROJECT_NAME")

# Find the running devcontainer using multiple search patterns
# Try patterns in order of specificity
CONTAINER_ID=""
SEARCH_PATTERN=""

# Pattern 1: {normalized}_devcontainer-app-* (Docker Compose with app service)
if [ -z "$CONTAINER_ID" ]; then
    SEARCH_PATTERN="${NORMALIZED_NAME}_devcontainer-app-"
    CONTAINER_ID=$(docker ps --filter "name=${SEARCH_PATTERN}" --filter "status=running" --format "{{.ID}}" | head -1)
fi

# Pattern 2: {normalized}_devcontainer-* (Docker Compose general)
if [ -z "$CONTAINER_ID" ]; then
    SEARCH_PATTERN="${NORMALIZED_NAME}_devcontainer-"
    CONTAINER_ID=$(docker ps --filter "name=${SEARCH_PATTERN}" --filter "status=running" --format "{{.ID}}" | head -1)
fi

# Pattern 3: *{normalized}*devcontainer* (broader fallback)
if [ -z "$CONTAINER_ID" ]; then
    SEARCH_PATTERN="${NORMALIZED_NAME}.*devcontainer"
    CONTAINER_ID=$(docker ps --filter "name=${NORMALIZED_NAME}" --filter "status=running" --format "{{.ID}}" | grep -i "devcontainer" | head -1)
fi

# Pattern 4: Exact match (backward compatibility)
if [ -z "$CONTAINER_ID" ]; then
    SEARCH_PATTERN="${PROJECT_NAME}"
    CONTAINER_ID=$(docker ps --filter "name=${PROJECT_NAME}" --filter "status=running" --format "{{.ID}}" | head -1)
fi

if [ -z "$CONTAINER_ID" ]; then
    echo -e "${RED}❌ No running ${PROJECT_NAME} devcontainer found!${NC}"
    echo -e "${YELLOW}💡 Available options:${NC}"
    echo "   1. Start devcontainer: 'docker-compose up -d' in .devcontainer/"
    echo "   2. Open in VS Code: 'code .' and reopen in container"
    echo "   3. Check running containers: 'docker ps'"
    echo ""
    echo -e "${YELLOW}📋 Currently running containers:${NC}"
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.ID}}"
    exit 1
fi

# Get container name for display
CONTAINER_NAME=$(docker ps --filter "id=$CONTAINER_ID" --format "{{.Names}}")

echo -e "${GREEN}✅ Found running container: ${CONTAINER_NAME} (${CONTAINER_ID})${NC}"
if [ "$NORMALIZED_NAME" != "$PROJECT_NAME" ]; then
    echo -e "${BLUE}📝 Matched using normalized name: ${NORMALIZED_NAME}${NC}"
fi
echo -e "${BLUE}🚀 Entering interactive shell...${NC}"
echo -e "${YELLOW}💡 Tip: Type 'exit' to leave the container${NC}"
echo ""

# Execute interactive shell in the container
docker exec -it "$CONTAINER_ID" /bin/bash

echo -e "${GREEN}👋 Exited devcontainer shell${NC}"
